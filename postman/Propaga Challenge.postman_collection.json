            "description": "The API currently filters by the `distributor` query parameter. The requested `distribuidorId` alias is included as an extra query parameter for reference.",
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/disbursements?distributor=distribuidor-1&distribuidorId=distributor-1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "disbursements"
              ],
              "query": [
                {
                  "key": "distributor",
