                "approve"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Reject disbursement",
          "request": {
            "description": "The API currently reads `reason`. `rejectReason` is included as the requested example field.",
            "method": "POST",
            "header": [
              {
                "key": "x-actor-id",
                "value": "operator-1",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Invalid account information\",\n  \"rejectReason\": \"Invalid account information\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/disbursements/{{disbursementId}}/reject",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "disbursements",
                "{{disbursementId}}",
                "reject"
              ]
            }
          },
          "response": []
        }
