generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum DisbursementStatus {
  pending
  approved
  rejected

  @@map("disbursement_status")
}

enum DisbursementAction {
  approved
  rejected

  @@map("disbursement_action")
}

model Disbursement {
  id              String                   @id @default(uuid()) @db.Uuid
  tenderoId       String                   @map("tendero_id")
  distribuidorId  String                   @map("distribuidor_id")
  amountCents     Int                      @map("amount_cents")
  currency        String                   @default("MXN")
  status          DisbursementStatus       @default(pending)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  decidedAt       DateTime?                @map("decided_at") @db.Timestamptz(6)
  decidedBy       String?                  @map("decided_by")
  rejectReason    String?                  @map("reject_reason")
  auditLogs       DisbursementAuditLog[]

  @@index([createdAt, id], map: "disbursements_created_at_id_idx")
  @@index([status], map: "disbursements_status_idx")
  @@index([distribuidorId], map: "disbursements_distribuidor_id_idx")
  @@index([amountCents], map: "disbursements_amount_cents_idx")
  @@map("disbursements")
}

model DisbursementAuditLog {
  id              String              @id @default(uuid()) @db.Uuid
  disbursementId  String              @map("disbursement_id") @db.Uuid
  action          DisbursementAction
  actorId         String              @map("actor_id")
  reason          String?
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  disbursement    Disbursement        @relation(fields: [disbursementId], references: [id], onDelete: Restrict)

  @@index([disbursementId], map: "disbursement_audit_logs_disbursement_id_idx")
  @@map("disbursement_audit_logs")
}
